{
  "name": "o1js-nitro-verifier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo:build-ui": "esbuild src/demo/browser.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=public/demo/app.js",
    "demo:generate-proof": "node dist/src/demo/generateEvenProofCli.js",
    "demo:server": "node dist/src/demo/server.js",
    "generate:fixtures": "tsx src/proof-program/generateSampleProof.ts",
    "parent:send-fixture": "node dist/src/parent/sendFixtureRequest.js",
    "test:local": "node --test dist/tests/local/*.test.js",
    "test": "npm run build && npm run test:local"
  },
  "dependencies": {
    "canonicalize": "^3.0.0",
    "cbor": "^10.0.12",
    "o1js": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
